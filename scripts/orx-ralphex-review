#!/bin/bash
#
# orx wrapper for ralphex custom review
#
# contract: receives one argument - path to prompt file
# the prompt embeds two wrapper directives:
#   1. a "Run this command to see the changes:" marker followed by a git diff
#      command. this script runs the diff itself and attaches the output as
#      changes.diff for orx to feed into the LLMs.
#   2. an optional "Progress log path:" marker followed by an absolute path to
#      the ralphex progress log. if present and the file exists, the tail of
#      that log is attached as iteration-history.log so models see history of
#      previous iterations without needing filesystem access.
#

set -euo pipefail

# tail size for progress log (64 KB, ~5-10 task iterations)
PROGRESS_TAIL_BYTES=65536

if [[ $# -ne 1 ]]; then
    echo "error: usage: $0 <prompt-file>" >&2
    exit 1
fi

PROMPT_FILE="$1"

if [[ ! -f "$PROMPT_FILE" ]]; then
    echo "error: prompt file not found: $PROMPT_FILE" >&2
    exit 1
fi

# verify jq is available early
if ! command -v jq >/dev/null 2>&1; then
    echo "error: jq is required but not found on PATH" >&2
    exit 1
fi

# extract git diff command: next non-empty line after the marker
DIFF_CMD=$(awk '/Run this command to see the changes:/ { found=1; next } found && NF { print; exit }' < "$PROMPT_FILE")
if [[ -z "$DIFF_CMD" ]]; then
    DIFF_CMD="git diff"
fi

# split into array instead of eval
read -r -a DIFF_ARGS <<< "$DIFF_CMD"
# guard against short arrays before indexing element 1
if [[ ${#DIFF_ARGS[@]} -lt 2 || "${DIFF_ARGS[0]}" != "git" || "${DIFF_ARGS[1]}" != "diff" ]]; then
    echo "error: unexpected command extracted: $DIFF_CMD" >&2
    exit 2
fi

# reject flags that bypass security controls or write diff to an arbitrary path
for _arg in "${DIFF_ARGS[@]:2}"; do
    case "$_arg" in
        --)
            break
            ;;
        --output=*|--output|--ext-diff|--textconv)
            echo "error: unsafe flag in diff command: $_arg" >&2
            exit 2
            ;;
    esac
done

# extract optional progress log path: next non-empty line after the marker
PROGRESS_PATH=$(awk '/Progress log path:/ { found=1; next } found && NF { print; exit }' < "$PROMPT_FILE")

# single tempdir with fixed filenames so orx shows human-readable paths to LLMs
TMPDIR_RUN=$(mktemp -d "${TMPDIR:-/tmp}/ralphex-orx.XXXXXX")
trap 'rm -rf "$TMPDIR_RUN" || true' EXIT INT TERM HUP

DIFF_FILE="$TMPDIR_RUN/changes.diff"
PROGRESS_FILE_LOCAL="$TMPDIR_RUN/iteration-history.log"
JSON_FILE="$TMPDIR_RUN/orx-result.json"

# --no-ext-diff --no-textconv: prevent .gitattributes from invoking external commands
if ! git -c color.ui=false diff --no-ext-diff --no-textconv "${DIFF_ARGS[@]:2}" > "$DIFF_FILE"; then
    echo "error: git diff failed" >&2
    exit 3
fi

# build orx file args: diff is always attached, progress is opt-in
ORX_FILE_ARGS=("-f" "$DIFF_FILE")
if [[ -n "$PROGRESS_PATH" && -f "$PROGRESS_PATH" ]]; then
    # tail the source to keep recent entries; orx --max-file-size 512KB is a hard cap,
    # but we want to control what the LLM actually sees
    tail -c "$PROGRESS_TAIL_BYTES" "$PROGRESS_PATH" > "$PROGRESS_FILE_LOCAL"
    ORX_FILE_ARGS+=("-f" "$PROGRESS_FILE_LOCAL")
fi

# run orx even with empty diff -- prompt may contain PREVIOUS REVIEW CONTEXT
# that external LLMs need to re-evaluate (dismiss flow).
# capture stdout (JSON) to temp file; let stderr (progress) pass through so
# ralphex can stream orx status updates (requesting/done) in real time.
# orx exits 1 on partial model failure, 2 on total failure; allow 1 (valid JSON may exist).
orx_exit=0
orx -p "$PROMPT_FILE" "${ORX_FILE_ARGS[@]}" --max-file-size 512KB \
    >"$JSON_FILE" || orx_exit=$?

if [[ $orx_exit -gt 1 ]]; then
    echo "error: orx failed (exit $orx_exit)" >&2
    exit 4
fi

# format JSON to plain text
if ! jq -r '
  .results[] |
  if .status == "success" then
    "=== \(.name) ===\n\(.content)\n"
  else
    "=== \(.name) [ERROR] ===\n\(.error // "unknown error")\n"
  end
' < "$JSON_FILE"; then
    echo "error: failed to parse orx output" >&2
    exit 4
fi
